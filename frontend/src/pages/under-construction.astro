---
import MainLayout from "../layouts/MainLayout.astro";
import BackgroundJPG from "../assets/background.jpg";
import { Image } from "astro:assets";
---

<MainLayout>
	<main class="w-full h-screen relative">
		<Image
			alt=""
			src={BackgroundJPG}
			class="brightness-20 w-full h-full object-cover object-center inset-0 absolute"
		/>

		<div
			class="px-10 max-w-[500px] w-max top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 absolute"
		>
			<h1 class="text-center text-2xl">Under Construction!</h1>
			<img src="/favicon.ico" class="my-4 mx-auto rounded-xl h-32" />
			<p class="text-center text-fore-2">
				Please check again later... maybe it'll be finished by then? Or
				if you're impatient, check out <a
					href="https://zf.flappygrant.com">the Zacfloor version</a
				> for something more complete!
			</p>
		</div>
	</main>
</MainLayout>
